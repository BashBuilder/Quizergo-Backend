generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Roles {
  STUDENT
  ADMIN
  TEACHER
}

enum KeyStatus {
  ACTIVE
  DEACTIVATED
}

enum Permissions {
  GENERAL
  ADMIN
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  firstName  String
  lastName   String
  role       Roles    @default(STUDENT)
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  keyStore    KeyStore?
  quizResults QuizResult[]

  @@index([id, email, isVerified])
}

model KeyStore {
  id           String    @id @default(uuid())
  client       String    @unique
  primaryKey   String
  secondaryKey String
  status       KeyStatus
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [client], references: [id])

  @@index([client, primaryKey, secondaryKey])
}

model ApiKey {
  id          String        @id @default(uuid())
  key         String        @unique
  version     Int           @default(1)
  permissions Permissions[]
  status      String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([id, version, key])
}

model Questions {
  id       String @id @default(uuid())
  question String
  options  Json
  answer   String

  mockId      Int
  section     String?
  image       String?
  solution    String?
  examtype    String?
  examyear    String?
  questionNub Int
  hasPassage  Boolean @default(false)
  category    String?

  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([id])
}

model QuizResult {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  sessionId String

  score     Int
  total     Int
  timeTaken Int

  correct   Json
  incorrect Json
  skipped   Json
  breakdown Json[]

  submittedAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([sessionId])
}
