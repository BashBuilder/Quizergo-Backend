generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  firstName  String
  lastName   String
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([id, email, isVerified])
}

enum Permissions {
  GENERAL
  ADMIN
}

model ApiKey {
  id          String        @id @default(uuid())
  key         String        @unique
  version     Int           @default(1)
  permissions Permissions[]
  status      String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([id, version])
}
