generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Roles {
  STUDENT
  ADMIN
  TEACHER
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  firstName  String
  lastName   String
  role       Roles    @default(STUDENT)
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  keyStore KeyStore?

  @@index([id, email, isVerified])
}

enum KeyStatus {
  ACTIVE
  DEACTIVATED
}

model KeyStore {
  id           String    @id @default(uuid())
  client       String    @unique
  primaryKey   String
  secondaryKey String
  status       KeyStatus
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [client], references: [id])

  @@index([client, primaryKey, secondaryKey])
}

enum Permissions {
  GENERAL
  ADMIN
}

model ApiKey {
  id          String        @id @default(uuid())
  key         String        @unique
  version     Int           @default(1)
  permissions Permissions[]
  status      String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([id, version, key])
}
