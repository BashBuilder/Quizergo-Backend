generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Roles {
  STUDENT
  ADMIN
  TEACHER
}

enum KeyStatus {
  ACTIVE
  DEACTIVATED
}

enum Permissions {
  GENERAL
  ADMIN
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  firstName  String
  lastName   String
  role       Roles    @default(STUDENT)
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  keyStore    KeyStore?
  quizResults QuizResult[]

  @@index([id, email, isVerified])
}

model KeyStore {
  id           String    @id @default(uuid())
  client       String    @unique
  primaryKey   String
  secondaryKey String
  status       KeyStatus
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [client], references: [id])

  @@index([client, primaryKey, secondaryKey])
}

model ApiKey {
  id          String        @id @default(uuid())
  key         String        @unique
  version     Int           @default(1)
  permissions Permissions[]
  status      String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([id, version, key])
}

// {
//   "a": "100",
//   "b": "200",
//   "c": "300",
//   "d": "400"
// }

model Question {
  id String @id @default(uuid())

  mockId String

  subject String
  topic   String?

  question String
  answer   String

  options Json

  solution String?

  image String?

  examType String?
  examYear String?

  version Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quizAnswers QuizAnswer[]

  @@index([subject])
}

