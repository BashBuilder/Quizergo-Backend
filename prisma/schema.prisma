model QuizResult {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  sessionId String @unique

  score Int
  total Int

  percentage Float

  timeTaken Int

  submittedAt DateTime

  // answers       QuizAnswer[]

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([submittedAt])
}
