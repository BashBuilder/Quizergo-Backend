generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Roles {
  STUDENT
  ADMIN
  TEACHER
}

enum KeyStatus {
  ACTIVE
  DEACTIVATED
}

enum Permissions {
  GENERAL
  ADMIN
}

enum QuestionStatus {
  CORRECT
  INCORRECT
  SKIPPED
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  firstName  String
  lastName   String
  role       Roles    @default(STUDENT)
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  keyStore    KeyStore?
  quizResults QuizResult[]

  @@index([id, email, isVerified])
}

model KeyStore {
  id           String    @id @default(uuid())
  client       String    @unique
  primaryKey   String
  secondaryKey String
  status       KeyStatus
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [client], references: [id])

  @@index([client, primaryKey, secondaryKey])
}

model ApiKey {
  id          String        @id @default(uuid())
  key         String        @unique
  version     Int           @default(1)
  permissions Permissions[]
  status      String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([id, version, key])
}

model Question {
  id String @id @default(uuid())

  mockId Int @unique

  subject String
  topic   String?

  question    String
  answer      String
  section     String
  questionNub Int?
  hasPassage  Boolean @default(false)
  category    String?

  options Json

  solution String?

  image String?

  examType String?
  examYear String?

  version Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quizAnswers QuizAnswer[]

  @@index([subject])
  @@index([subject, topic])
  @@index([subject, examYear])
  @@index([mockId, subject])
}

model QuizResult {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  sessionId String @unique

  score Int
  total Int

  answers QuizAnswer[]

  timeTaken   Int
  submittedAt DateTime
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([submittedAt])
}

model QuizAnswer {
  id String @id @default(uuid())

  quizResultId String
  quizResult   QuizResult @relation(fields: [quizResultId], references: [id], onDelete: Cascade)

  questionId String
  question   Question @relation(fields: [questionId], references: [id])

  subject String

  userAnswer String?

  status QuestionStatus

  questionSnapshot Json

  createdAt DateTime @default(now())

  @@index([quizResultId])
  @@index([questionId])
  @@index([subject])
  @@index([status])
}
